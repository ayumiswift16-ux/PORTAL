rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // === helpers ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isHardcodedAdmin() {
      return isSignedIn() && request.auth.token.email != null && (
        request.auth.token.email == 'davevenzon789@gmail.com' || 
        request.auth.token.email.matches('.*admin[1-5]@school\\.portal$')
      );
    }

    function isAdmin() {
      return isHardcodedAdmin() || (
        isSignedIn() && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          (request.auth.token.email != null && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)))
        )
      );
    }

    function isApprovedProfessor() {
      return isSignedIn() && (
        (request.auth.token.email != null && exists(/databases/$(database)/documents/admins/$(request.auth.token.email))) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'professor')
      );
    }

    function getProfessorData() {
      let email = request.auth.token.email;
      return (email != null && exists(/databases/$(database)/documents/admins/$(email)))
        ? get(/databases/$(database)/documents/admins/$(email)).data
        : (exists(/databases/$(database)/documents/admins/$(request.auth.uid)))
          ? get(/databases/$(database)/documents/admins/$(request.auth.uid)).data
          : get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // === Collections ===

    match /users/{userId} {
      allow list: if true; 
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isApprovedProfessor());
      allow update, delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn();
    }

    match /admins/{emailId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow read: if isSignedIn() && (
        emailId == request.auth.token.email || 
        emailId == request.auth.uid ||
        isAdmin()
      );
      allow write: if isAdmin();
    }

    match /enrollments/{enrollmentId} {
      allow list: if isAdmin() || (isSignedIn() && (
          resource.data.userId == request.auth.uid ||
          (request.auth.token.email != null && resource.data.studentInfo.email == request.auth.token.email) ||
          (isApprovedProfessor() && (
            resource.data.section in getProfessorData().get('assignedSections', [])
          ))
        ));
        
      allow get: if isAdmin() || (isSignedIn() && (
          resource.data.userId == request.auth.uid ||
          (request.auth.token.email != null && resource.data.studentInfo.email == request.auth.token.email) ||
          (isApprovedProfessor() && (
            resource.data.section in getProfessorData().get('assignedSections', [])
          ))
        )) ||
        (isSignedIn() && (
           enrollmentId == request.auth.uid ||
           (request.auth.token.email != null && request.auth.token.email.matches(enrollmentId + '@school\\.portal$'))
        ));

      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (
        enrollmentId == request.auth.uid ||
        (resource != null && (
          resource.data.userId == request.auth.uid ||
          (request.auth.token.email != null && resource.data.studentInfo.email == request.auth.token.email)
        )) ||
        (isApprovedProfessor() && (
           resource.data.section in getProfessorData().get('assignedSections', [])
        ))
      ));
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
    }

    match /teacher_requests/{requestId} {
      allow get, list: if true; 
      allow create: if true;
      allow update: if isAdmin() || (request.resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || isSignedIn();
    }
    
    match /schedules/{scheduleId} {
       allow read: if true;
       allow write: if isAdmin() || isApprovedProfessor();
    }

    match /sections/{sectionId} {
       allow read: if true;
    }
    
    match /courses/{courseId} {
      allow read: if true;
    }
  }
}
