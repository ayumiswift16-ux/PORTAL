rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // === helpers ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.email.matches('.*@school\\.portal$')
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && (
          request.auth.token.email == 'davevenzon789@gmail.com' || 
          request.auth.token.email.matches('admin[1-5]@school\\.portal$')
        )) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email != null && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)))
      );
    }

    function isApprovedProfessor() {
      return isSignedIn() && (
        // Check local users doc
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('role', '') == 'professor') ||
        // OR check admins collection where professors are mirrored
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email != null && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)))
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins can do everything
    match /{path=**} {
      allow read, write: if isAdmin();
    }

    // === Collections ===

    match /users/{userId} {
      allow list: if isSignedIn(); // Allow searching for roles, etc.
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /admins/{emailId} {
      allow list: if isAdmin();
      // Allow users to read their own admin entry to verify roles
      allow read: if isAdmin() || (
        isSignedIn() && request.auth.token.email != null && (
          emailId == request.auth.token.email ||
          emailId == request.auth.uid
        )
      );
    }

    match /enrollments/{enrollmentId} {
      allow list: if isAdmin() || 
        (isSignedIn() && (
          resource.data.studentInfo.email == request.auth.token.email || 
          resource.data.userId == request.auth.uid
        )) ||
        (isApprovedProfessor() && (
          resource.data.section == getUserData().get('assignedSection', null) || 
          resource.data.section in getUserData().get('assignedSections', [])
        ));
        
      allow get: if isAdmin() || 
        (isSignedIn() && resource.data != null && (
          resource.data.studentInfo.email == request.auth.token.email || 
          resource.data.userId == request.auth.uid
        )) ||
        (isApprovedProfessor() && resource.data != null && (
          resource.data.section == getUserData().get('assignedSection', null) || 
          resource.data.section in getUserData().get('assignedSections', [])
        )) ||
        // Allow student to fetch their OWN record even if it doesn't exist yet (for creation check)
        (isSignedIn() && (
           enrollmentId == request.auth.uid ||
           (request.auth.token.email != null && enrollmentId == request.auth.token.email.replace('@school.portal', ''))
        ));

      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (
        // Students can write their own enrollment
        enrollmentId == request.auth.uid ||
        (resource != null && resource.data.userId == request.auth.uid) ||
        (request.auth.token.email != null && enrollmentId == request.auth.token.email.replace('@school.portal', '')) ||
        (isApprovedProfessor() && (
           resource.data.section == getUserData().get('assignedSection', null) || 
           resource.data.section in getUserData().get('assignedSections', [])
        ))
      ));
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
    }

    match /teacher_requests/{requestId} {
      allow list: if isAdmin();
      allow get: if true; 
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.userId != null);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
    
    match /schedules/{scheduleId} {
       allow read: if true;
       allow write: if isAdmin() || isApprovedProfessor();
    }

    match /sections/{sectionId} {
       allow read: if true;
    }
    
    match /courses/{courseId} {
      allow read: if true;
    }
  }
}
