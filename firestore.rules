rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'davevenzon789@gmail.com' ||
        request.auth.token.email.matches('.*@school\\.portal') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || request.auth.token.email == 'davevenzon789@gmail.com');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins have full access to everything
    match /{path=**} {
      allow read, write: if isAdmin();
    }

    // Settings
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Courses
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn();
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Enrollments
    match /enrollments/{enrollmentId} {
      allow list: if isSignedIn() && (
        isAdmin() || 
        (resource != null && (resource.data.studentInfo.email == request.auth.token.email || resource.data.userId == request.auth.uid))
      );
      allow get: if isSignedIn() && (
        isAdmin() || 
        enrollmentId == request.auth.uid ||
        (resource != null && (resource.data.studentInfo.email == request.auth.token.email || resource.data.userId == request.auth.uid)) ||
        (resource == null)
      );
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.studentInfo.email == request.auth.token.email ||
        (resource == null)
      ));
      allow delete: if isAdmin();
    }

    // Sections
    match /sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
    
    // System settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
