# Email Credentials for Verification
# 1. Use your full Gmail address for EMAIL_USER
# 2. Use a 16-character 'App Password' for EMAIL_PASS. 
#    DO NOT use your normal account password.
#    To generate one: 
#    - Enable 2-Step Verification in Google Settings
#    - Visit https://myaccount.google.com/apppasswords
#    - Create a new app name 'School Portal' and copy the 16-char code.

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
